<!DOCTYPE html>
<html>
<head>
<title>SIP Calculator</title>

<style>

body{
font-family: Arial;
background:#f2f2f2;
text-align:center;
margin-top:100px;
}

.container{
background:white;
padding:30px;
width:300px;
margin:auto;
border-radius:10px;
box-shadow:0 0 10px gray;
}

input{
width:90%;
padding:10px;
margin:10px 0;
}

button{
padding:10px 20px;
background:green;
color:white;
border:none;
cursor:pointer;
}

</style>

</head>

<body>

<div class="container">

<h2>SIP Calculator</h2>

<input type="number" id="investment" placeholder="Monthly Investment">

<input type="number" id="rate" placeholder="Expected Return (%)">

<input type="number" id="years" placeholder="Time (Years)">

<button onclick="calculateSIP()">Calculate</button>

<h3 id="result"></h3>

</div>

<script>

function calculateSIP(){

let P = document.getElementById("investment").value;

let r = document.getElementById("rate").value / 12 / 100;

let n = document.getElementById("years").value * 12;

let FV = P * ((Math.pow(1+r,n)-1)/r)*(1+r);

document.getElementById("result").innerHTML =
"Total Value = ₹ " + Math.round(FV);

}

</script>

</body>
</html>
